generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
}

model admin {
  id       Int    @id @default(autoincrement())
  adminId  String @unique
  password String
}

model Order {
  id                Int         @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String
  phone             String
  address           String
  city              String
  state             String
  pincode           String
  paymentMethod     String
  totalAmount       Int
  createdAt         DateTime    @default(now())
  paymentStatus     String      @default("pending")
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?
  razorpaySignature String?
  items             OrderItem[]
  discountApplied   Boolean     @default(false)
  discountAmount    Int         @default(0)
  academicDetails   AcademicDetails?
}

model OrderItem {
  id       Int    @id @default(autoincrement())
  name     String
  quantity Int
  price    Int
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Product {
  id            String   @id
  name          String
  description   String?
  stockQuantity Int      @default(0)
  createdAt     DateTime @default(now())
  code          String   @unique
  price         Int
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AcademicDetails {
  id            Int      @id @default(autoincrement())
  studentName   String
  academyName   String
  studentAddress String
  orderId       Int      @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}
