generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
}

model admin {
  id       Int    @id @default(autoincrement())
  adminId  String @unique
  password String
}

model Order {
  id                Int              @id @default(autoincrement())
  firstName         String
  lastName          String
  email             String
  phone             String
  address           String
  city              String
  state             String
  pincode           String
  paymentMethod     String
  totalAmount       Int
  createdAt         DateTime         @default(now())
  paymentStatus     String           @default("pending")
  deliveryStatus    String           @default("In Progress")
  razorpayOrderId   String?          @unique
  razorpayPaymentId String?
  razorpaySignature String?
  discountAmount    Int              @default(0)
  discountApplied   Boolean          @default(false)
  academicDetails   AcademicDetails?
  items             OrderItem[]
}

model OrderItem {
  id       Int    @id @default(autoincrement())
  name     String
  quantity Int
  price    Int
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // ✅ Color selected by the user (nullable for products without color)
  productColorId Int?
  productColor   ProductColor? @relation(fields: [productColorId], references: [id])

  selectedColor    String?
  selectedColorHex String?
}

model Product {
  id            String         @id
  name          String
  description   String?
  stockQuantity Int            @default(0)
  createdAt     DateTime       @default(now())
  code          String         @unique
  price         Int
  // ✅ Optional relation to available colors
  colors        ProductColor[]
}

model ProductColor {
  id          Int     @id @default(autoincrement())
  name        String // e.g. "Red", "Blue", "Black"
  hexCode     String? // Optional for UI (#FF0000)
  productCode String
  product     Product @relation(fields: [productCode], references: [code], onDelete: Cascade)

  // ✅ Opposite side of OrderItem relation
  orderItems OrderItem[]

  @@unique([productCode, name]) // ✅ Compound unique key
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AcademicDetails {
  id             Int      @id @default(autoincrement())
  studentName    String
  academyName    String
  academyNo      String?
  studentAddress String
  orderId        Int      @unique
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
